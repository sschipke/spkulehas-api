{
  "name": "spkulehas-api",
  "version": "1.0.0",
  "description": "Api for managing reservations for the SpKuLeHaS Cabin",
  "license": "UNLICENSED",
  "author": "Scott Schipke",
  "main": "server.js",
  "type": "module",
  "husky": {
    "hooks": {
      "pre-commit": "yarn lint",
      "pre-push": "yarn lint"
    }
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --exec babel-node src/server.js",
    "dev:test": "NODE_ENV=test nodemon --exec babel-node src/server.js",
    "compile": "yarn babel src --out-dir build --copy-files && cp -r src/db build/db && cp package.json ./build && cp yarn.lock ./build && cp -r ./config ./build",
    "initdb": "NODE_ENV=development node -r dotenv/config ./node_modules/knex/bin/cli.js migrate:latest --knexfile ./src/knexfile.js && NODE_ENV=development node -r dotenv/config ./node_modules/knex/bin/cli.js seed:run --knexfile ./src/knexfile.js",
    "migrate:dev": "NODE_ENV=development node -r dotenv/config ./node_modules/knex/bin/cli.js migrate:latest --knexfile ./src/knexfile.js",
    "migrate:test": "NODE_ENV=test node -r dotenv/config ./node_modules/knex/bin/cli.js migrate:latest --knexfile ./src/knexfile.js",
    "migrate": "knex migrate:latest",
    "rollback": "knex migrate:rollback",
    "seed:dev": "NODE_ENV=development node -r dotenv/config ./node_modules/knex/bin/cli.js seed:run --knexfile ./src/knexfile.js",
    "seed:test": "NODE_ENV=test node -r dotenv/config ./node_modules/knex/bin/cli.js seed:run --knexfile ./src/knexfile.js",
    "addNewSeasonReservations:dev": "NODE_ENV=development node -r dotenv/config ./node_modules/knex/bin/cli.js seed:run --specific=add_new_reservations.cjs --knexfile ./src/knexfile.js",
    "addNewSeasonReservations": "knex seed:run --specific=add_new_reservations.cjs",
    "down:dev": "NODE_ENV=development node -r dotenv/config ./node_modules/knex/bin/cli.js migrate:down --knexfile ./src/knexfile.js",
    "down": "knex migrate:down",
    "test": "jest --forceExit",
    "test:watch": "jest --watchAll",
    "lint": "eslint 'src/**/*.js'",
    "lint:fix": "eslint --fix 'src/**/*.js'",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable",
    "test:build": "yarn compile && cp .env ./build && NODE_ENV='alpha' && node build/server.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "config": "^3.3.12",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "express": "^4.17.1",
    "express-rate-limit": "^6.4.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.7",
    "nodemailer-express-handlebars": "^5.0.0",
    "nodemon": "^3.1.9",
    "pg": "^8.13.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.26.4",
    "@babel/core": "^7.26.7",
    "@babel/node": "^7.26.0",
    "@babel/preset-env": "^7.26.7",
    "@eslint/js": "^9.19.0",
    "babel-node": "^0.0.1-security",
    "babel-watch": "^7.8.1",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "pinst": "^3.0.0",
    "prettier": "^3.4.2",
    "regenerator-runtime": "^0.13.7",
    "supertest": "^4.0.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "yarn": "latest"
  },
  "resolutions": {
    "tar": "7.5.13",
    "minimatch@^3.1.1": "3.1.4",
    "minimatch@^3.1.2": "3.1.4",
    "minimatch@^9.0.4": "9.0.7",
    "brace-expansion@^1.1.7": "1.1.14",
    "brace-expansion@^2.0.1": "2.1.0",
    "handlebars": "4.7.9",
    "picomatch": "2.3.2",
    "flatted": "3.4.2",
    "path-to-regexp": "0.1.13",
    "lodash": "4.18.0"
  },
  "packageManager": "yarn@4.6.0"
}
